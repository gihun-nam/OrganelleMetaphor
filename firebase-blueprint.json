{
  "entities": {
    "School": {
      "title": "School",
      "description": "Information about registered school and classroom info",
      "type": "object",
      "properties": {
        "schoolName": {
          "type": "string",
          "description": "The real school name, like 서울고등학교"
        },
        "normalizedSchoolName": {
          "type": "string",
          "description": "Lowercase trimmed version of the school name"
        },
        "className": {
          "type": "string",
          "description": "Class identifier or empty string"
        },
        "teacherPin": {
          "type": "string",
          "description": "Admin/teacher access pin code"
        },
        "studentPassword": {
          "type": "string",
          "description": "Access password for student login"
        },
        "joinCode": {
          "type": "string",
          "description": "6-character unique code to join the school room"
        },
        "createdAt": {
          "type": "string",
          "description": "ISO String representation of date created"
        },
        "updatedAt": {
          "type": "string",
          "description": "ISO String representation of date updated"
        },
        "isActive": {
          "type": "boolean",
          "description": "Active status of the room"
        }
      },
      "required": [
        "schoolName",
        "normalizedSchoolName",
        "teacherPin",
        "studentPassword",
        "joinCode",
        "createdAt",
        "updatedAt",
        "isActive"
      ]
    },
    "TestConnection": {
      "title": "TestConnection",
      "description": "Metadata for verifying real connection and synchronisation",
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "required": [
        "status",
        "updatedAt",
        "message"
      ]
    },
    "Submission": {
      "title": "Submission",
      "description": "Metaphor submission details written by students",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "schoolId": {
          "type": "string"
        },
        "schoolName": {
          "type": "string"
        },
        "normalizedSchoolName": {
          "type": "string"
        },
        "studentName": {
          "type": "string"
        },
        "studentClass": {
          "type": "string"
        },
        "organelleId": {
          "type": "string"
        },
        "organelleName": {
          "type": "string"
        },
        "metaphorSubject": {
          "type": "string"
        },
        "metaphorReason": {
          "type": "string"
        },
        "ratings": {
          "type": "object"
        },
        "averageRating": {
          "type": "number"
        },
        "ratingCount": {
          "type": "number"
        },
        "customImage": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        },
        "isDeleted": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "schoolId",
        "schoolName",
        "normalizedSchoolName",
        "studentName",
        "studentClass",
        "organelleId",
        "organelleName",
        "metaphorSubject",
        "metaphorReason",
        "ratings",
        "averageRating",
        "ratingCount",
        "createdAt",
        "updatedAt",
        "isDeleted"
      ]
    },
    "SubmissionCheck": {
      "title": "SubmissionCheck",
      "description": "Safety check result generated by Gemini AI for student metaphor",
      "type": "object",
      "properties": {
        "submissionId": {
          "type": "string"
        },
        "schoolId": {
          "type": "string"
        },
        "classId": {
          "type": "string"
        },
        "schoolName": {
          "type": "string"
        },
        "className": {
          "type": "string"
        },
        "checked": {
          "type": "boolean"
        },
        "needsReview": {
          "type": "boolean"
        },
        "categories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "flaggedSpans": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "field": { "type": "string" },
              "text": { "type": "string" },
              "reason": { "type": "string" }
            },
            "required": ["field", "text", "reason"]
          }
        },
        "summary": {
          "type": "string"
        },
        "checkedAt": {
          "type": "object",
          "description": "Firestore Timestamp object"
        },
        "model": {
          "type": "string"
        },
        "sourceHash": {
          "type": "string"
        },
        "error": {
          "type": "boolean"
        },
        "errorMessage": {
          "type": "string"
        }
      },
      "required": [
        "submissionId",
        "schoolName",
        "className",
        "checked",
        "needsReview",
        "categories",
        "flaggedSpans",
        "summary",
        "checkedAt",
        "model",
        "sourceHash"
      ]
    }
  },
  "firestore": {
    "/schools/{schoolId}": {
      "schema": "School",
      "description": "School registrations and access control"
    },
    "/submissions/{schoolId}/{classId}/{studentFolderId}": {
      "schema": "Submission",
      "description": "Student metaphor creations"
    },
    "/submission_checks/{schoolId}/{classId}/{studentFolderId}": {
      "schema": "SubmissionCheck",
      "description": "Safety checks matching student metaphor submission documents"
    },
    "/test/{testId}": {
      "schema": "TestConnection",
      "description": "Firestore connection testing documents"
    }
  }
}
